---
import { SITE, NAV } from "../config";
---

<header class="border-b border-slate-200 bg-white">
  <div class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4">
    <a href="/" class="text-lg font-semibold tracking-tight text-slate-900">
      {SITE.name}
    </a>
    <nav class="flex items-center gap-4 text-sm font-medium">
      <a href={NAV.login} class="text-slate-600 hover:text-slate-950">Log in</a>
      <a
        href={NAV.register}
        class="rounded-lg bg-sky-600 px-4 py-2 text-white hover:bg-sky-700"
      >
        Register
      </a>
    </nav>
  </div>
</header>

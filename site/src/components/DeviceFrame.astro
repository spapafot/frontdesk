---
interface Props {
  label: string;
}
const { label } = Astro.props;
---

<div
  class="overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-xl shadow-slate-900/5"
>
  <div class="flex items-center gap-2 border-b border-slate-200 bg-slate-50 px-4 py-2.5">
    <span class="h-2.5 w-2.5 rounded-full bg-red-300"></span>
    <span class="h-2.5 w-2.5 rounded-full bg-amber-300"></span>
    <span class="h-2.5 w-2.5 rounded-full bg-emerald-300"></span>
    <span class="ml-2 text-xs font-medium text-slate-400">{label}</span>
  </div>
  <slot />
</div>

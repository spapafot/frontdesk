---
import DeviceFrame from "./DeviceFrame.astro";

const metrics = [
  { label: "Conversations", value: "1,284" },
  { label: "Last 7 days", value: "196" },
  { label: "Helpful", value: "472" },
  { label: "Not helpful", value: "23" },
];
const unanswered = ["Do you offer a student discount?", "Is there an API for exports?"];
---

<DeviceFrame label="Logs & analytics">
  <div class="space-y-4 p-5">
    <div class="grid grid-cols-2 gap-3 sm:grid-cols-4">
      {
        metrics.map((metric) => (
          <div class="rounded-xl border border-slate-200 bg-white p-4">
            <p class="text-2xl font-semibold text-slate-800">{metric.value}</p>
            <p class="mt-1 text-xs uppercase tracking-wide text-slate-400">{metric.label}</p>
          </div>
        ))
      }
    </div>

    <div>
      <p class="text-xs font-semibold uppercase tracking-wide text-slate-400">
        Unanswered questions
      </p>
      <div class="mt-2 space-y-2">
        {
          unanswered.map((question) => (
            <div class="flex items-center justify-between rounded-lg border border-slate-200 bg-white px-3 py-2">
              <p class="truncate text-sm text-slate-700">{question}</p>
              <span class="ml-3 shrink-0 text-xs font-medium text-sky-600">Open chat</span>
            </div>
          ))
        }
      </div>
    </div>

    <div class="flex items-center justify-between rounded-lg bg-slate-50 px-3 py-2">
      <span class="text-sm text-slate-600">Every answer can be rated by your visitors</span>
      <div class="flex items-center gap-2">
        <span class="text-xs text-slate-400">Helpful?</span>
        <span class="rounded bg-emerald-100 p-1 text-emerald-700">
          <svg viewBox="0 0 24 24" class="h-4 w-4" fill="currentColor" aria-hidden="true">
            <path
              d="M2 21h2c.55 0 1-.45 1-1v-9c0-.55-.45-1-1-1H2v11zm19.83-7.12c.11-.25.17-.52.17-.8V11c0-1.1-.9-2-2-2h-5.5l.92-4.65c.05-.22.02-.46-.08-.66a4.8 4.8 0 0 0-.88-1.17L14 2 7.59 8.41C7.21 8.79 7 9.3 7 9.83v7.84A2.34 2.34 0 0 0 9.34 20h8.11c.7 0 1.36-.37 1.72-.97l2.66-5.15z"
            ></path>
          </svg>
        </span>
        <span class="rounded p-1 text-slate-400">
          <svg viewBox="0 0 24 24" class="h-4 w-4 rotate-180" fill="currentColor" aria-hidden="true">
            <path
              d="M2 21h2c.55 0 1-.45 1-1v-9c0-.55-.45-1-1-1H2v11zm19.83-7.12c.11-.25.17-.52.17-.8V11c0-1.1-.9-2-2-2h-5.5l.92-4.65c.05-.22.02-.46-.08-.66a4.8 4.8 0 0 0-.88-1.17L14 2 7.59 8.41C7.21 8.79 7 9.3 7 9.83v7.84A2.34 2.34 0 0 0 9.34 20h8.11c.7 0 1.36-.37 1.72-.97l2.66-5.15z"
            ></path>
          </svg>
        </span>
      </div>
    </div>
  </div>
</DeviceFrame>

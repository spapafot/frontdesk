---
import DeviceFrame from "./DeviceFrame.astro";

// Static reimplementation of the app's WidgetInstall snippet card.
const siteKey = "fd_live_9c2a4e17b83f4d10";
const snippet = `<script
  src="https://cdn.plugandplay.gr/widget.js"
  data-site-key="${siteKey}"
  data-accent="#0284c7"
  data-position="bottom-right"
  async
></script>`;
---

<DeviceFrame label="Settings · Website installation">
  <div class="px-5 py-6">
    <h3 class="text-sm font-semibold text-slate-800">Install on your website</h3>
    <p class="mt-1 text-xs text-slate-500">
      Paste this snippet just before the closing &lt;/body&gt; tag on your site.
    </p>

    <div class="mt-3">
      <label class="block text-xs font-medium text-slate-600">Site key</label>
      <code
        class="mt-1 block w-full rounded-lg border border-slate-200 bg-slate-50 px-3 py-2 text-xs text-slate-700"
        >{siteKey}</code
      >
    </div>

    <div class="mt-3">
      <label class="block text-xs font-medium text-slate-600">Embed snippet</label>
      <pre
        class="mt-1 overflow-x-auto rounded-lg border border-slate-200 bg-slate-900 px-3 py-3 text-xs leading-relaxed text-slate-100">{snippet}</pre>
      <div class="mt-2 flex gap-2">
        <span class="rounded-full bg-slate-800 px-4 py-1.5 text-xs font-medium text-white">
          Copy snippet
        </span>
        <span
          class="rounded-full border border-red-300 px-4 py-1.5 text-xs font-medium text-red-700"
        >
          Rotate key
        </span>
      </div>
    </div>
  </div>
</DeviceFrame>

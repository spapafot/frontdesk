---
import { SITE } from "../config";
import { LEGAL_ORDER, LEGAL_PAGES } from "../data/legal";

const year = new Date().getFullYear();
---

<footer class="border-t border-slate-200 bg-white">
  <div
    class="mx-auto flex max-w-6xl flex-col gap-3 px-6 py-6 text-sm text-slate-500 sm:flex-row sm:items-center sm:justify-between"
  >
    <p class="flex items-center gap-2">
      <img src="/logo.png" alt="" class="h-9 w-auto" />
      &copy; {year} {SITE.name}. All rights reserved.
    </p>
    <nav aria-label="Legal" class="flex flex-wrap gap-x-5 gap-y-2">
      {
        LEGAL_ORDER.map((slug) => (
          <a href={`/${slug}`} class="hover:text-slate-900">
            {LEGAL_PAGES[slug].title}
          </a>
        ))
      }
    </nav>
  </div>
</footer>

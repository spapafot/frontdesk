---
import BaseLayout from "../layouts/BaseLayout.astro";
import { SITE } from "../config";
import { LEGAL_CONTACT } from "../data/legal";

const path = "/contact";
const description =
  "Get in touch with the Plug & Play team about the product, billing, or privacy.";
const schema = [
  {
    "@context": "https://schema.org",
    "@type": "ContactPage",
    name: `Contact ${SITE.name}`,
    url: new URL(path, SITE.url).href,
  },
];
---

<BaseLayout title="Contact" description={description} path={path} schema={schema}>
  <section class="mx-auto max-w-3xl px-6 py-20">
    <p class="text-sm font-semibold uppercase tracking-widest text-sky-700">Contact</p>
    <h1 class="mt-4 text-4xl font-semibold tracking-tight">Get in touch</h1>
    <p class="mt-6 text-lg leading-8 text-slate-600">
      Questions about the product, your plan and billing, or a privacy request? Email us
      and a real person will get back to you.
    </p>

    <div class="mt-10 rounded-2xl border border-slate-200 bg-white p-8 shadow-sm">
      <p class="text-sm font-medium uppercase tracking-wide text-slate-500">Email</p>
      <a
        href={`mailto:${LEGAL_CONTACT}`}
        class="mt-2 inline-block text-2xl font-semibold text-sky-700 hover:text-sky-800"
      >
        {LEGAL_CONTACT}
      </a>
      <p class="mt-4 text-sm leading-7 text-slate-600">
        Use the same address for privacy and data requests under the GDPR - see our
        <a href="/privacy-policy" class="text-sky-700 underline hover:text-sky-800"
          >Privacy Policy</a
        >. We aim to reply within two business days.
      </p>
    </div>
  </section>
</BaseLayout>

---
import BaseLayout from "../layouts/BaseLayout.astro";
import FeatureRow from "../components/FeatureRow.astro";
import ChatShowcase from "../components/ChatShowcase.astro";
import KnowledgeShowcase from "../components/KnowledgeShowcase.astro";
import InstallShowcase from "../components/InstallShowcase.astro";
import AnalyticsShowcase from "../components/AnalyticsShowcase.astro";
import UrlIngestShowcase from "../components/UrlIngestShowcase.astro";
import FaqShowcase from "../components/FaqShowcase.astro";
import LiveSupportShowcase from "../components/LiveSupportShowcase.astro";
import WidgetCustomizeShowcase from "../components/WidgetCustomizeShowcase.astro";
import TicketsShowcase from "../components/TicketsShowcase.astro";
import { SITE, NAV } from "../config";

// Full schema markup for the home page: the responsible organisation, the
// website, and the product itself.
const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    name: SITE.name,
    url: SITE.url,
    logo: new URL("/logo-icon-full-color-512.png", SITE.url).href,
    description: SITE.description,
  },
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: SITE.name,
    url: SITE.url,
  },
  {
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    name: SITE.name,
    applicationCategory: "BusinessApplication",
    operatingSystem: "Web",
    description: SITE.description,
    url: SITE.url,
  },
];
---

<BaseLayout title={SITE.name} description={SITE.description} path="/" schema={schema}>
  <!-- Hero- the main selling point, shown as much as told. -->
  <section class="relative overflow-hidden border-b border-slate-200 bg-white">
    <div
      aria-hidden="true"
      class="pointer-events-none absolute inset-x-0 -top-32 h-72 bg-gradient-to-b from-sky-50 to-transparent"
    >
    </div>
    <div
      class="relative mx-auto grid max-w-6xl items-center gap-14 px-6 py-20 sm:py-28 lg:grid-cols-2"
    >
      <div>
        <p class="text-sm font-semibold uppercase tracking-widest text-sky-700">
          Customer support, grounded in your own documents
        </p>
        <h1 class="mt-5 text-4xl font-semibold tracking-tight text-slate-950 sm:text-6xl">
          Answers your customers can trust, right on your website.
        </h1>
        <p class="mt-6 max-w-xl text-lg leading-8 text-slate-600">
          {SITE.name} turns the documents you already have into a support assistant that
          replies in your customer's language- and only from what you've approved. Drop in
          one line of code and it's live.
        </p>
        <div class="mt-9 flex flex-wrap items-center gap-4">
          <a
            href={NAV.register}
            class="inline-flex rounded-lg bg-sky-600 px-5 py-3 text-sm font-medium text-white transition hover:bg-sky-700"
          >
            Go to your workspace
          </a>
          <a
            href="#features"
            class="inline-flex rounded-lg border border-slate-300 bg-white px-5 py-3 text-sm font-medium text-slate-700 transition hover:bg-slate-50"
          >
            See how it works
          </a>
        </div>
      </div>
      <div class="lg:pl-6">
        <ChatShowcase
          label="assistant.yoursite.com"
          question="Do you ship to Canada, and how long does it take?"
          answer="Yes- we ship to Canada. Standard delivery is 5–7 business days, and express is 2–3 business days."
        />
      </div>
    </div>
  </section>

  <div id="features">
    <!-- 1 · text right, content left (alternates from the hero) -->
    <FeatureRow
      tone="muted"
      reverse
      eyebrow="Grounded, multilingual chat"
      title="It answers from your knowledge- not guesswork."
      body="Every reply is retrieved from the documents you uploaded and streamed back in the visitor's own language. When the answer isn't in your knowledge base, the assistant says so instead of inventing one."
      bullets={[
        "Replies in the language the customer writes in",
        "Grounded in your documents- no invented answers",
        "Streams responses in real time",
      ]}
    >
      <ChatShowcase
        label="assistant.yoursite.com"
        question="¿Puedo cambiar mi plan a mitad de mes?"
        answer="Sí. Puedes cambiar de plan en cualquier momento y solo pagarás la diferencia prorrateada del mes en curso."
      />
    </FeatureRow>

    <!-- 2 · text left, content right -->
    <FeatureRow
      tone="light"
      eyebrow="Document knowledge base"
      title="Upload what you know. That's the setup."
      body="Add PDFs, Word files, spreadsheets, or plain text. Plug & Play extracts and indexes them into searchable chunks. Disable a document to take it out of answers, or remove it entirely- no re-uploading to update."
      bullets={[
        "PDF, DOC, DOCX, TXT, XLS, and XLSX",
        "See how many chunks each file produced",
        "Turn sources on or off without deleting them",
      ]}
    >
      <KnowledgeShowcase />
    </FeatureRow>

    <!-- 3 · text right, content left -->
    <FeatureRow
      tone="muted"
      reverse
      eyebrow="Secure website installation"
      title="One line of code, on the site you authorize."
      body="Paste a single script tag before your closing body tag and the assistant appears in an isolated widget. It runs only on the exact origin you approve, with signed sessions and a site key you can rotate at any time."
      bullets={[
        "Isolated widget that won't touch your page styles",
        "Locked to the one origin you authorize",
        "Rotate the site key whenever you need to",
      ]}
    >
      <InstallShowcase />
    </FeatureRow>

    <!-- 4 · text left, content right -->
    <FeatureRow
      tone="light"
      eyebrow="Analytics & feedback"
      title="See what customers ask- and what you're missing."
      body="Review every conversation, track helpful and unhelpful ratings, and surface the questions your knowledge base couldn't answer. Each gap is a clear signal for the next document to add."
      bullets={[
        "Volume, ratings, and 7-day trends at a glance",
        "A running list of unanswered questions",
        "Open any conversation to read the full transcript",
      ]}
    >
      <AnalyticsShowcase />
    </FeatureRow>

    <!-- 5 · text right, content left -->
    <FeatureRow
      tone="muted"
      reverse
      eyebrow="Web page knowledge"
      title="Add a web page, not just a file."
      body="Paste a URL and Plug & Play reads the page, cleans it up, and indexes it like any other document. Keep your help center and product pages answering for you- no copy and paste."
      bullets={[
        "Turn any public page into answers",
        "Cleaned and chunked automatically",
        "Works alongside your uploaded files",
      ]}
    >
      <UrlIngestShowcase />
    </FeatureRow>

    <!-- 6 · text left, content right -->
    <FeatureRow
      tone="light"
      eyebrow="Quick FAQs"
      title="Answer common questions in seconds."
      body="Add a question and its answer- no file needed. FAQs are indexed the moment you save them, so the assistant can start replying right away."
      bullets={[
        "Add question-and-answer pairs in the app",
        "Live on save- no upload required",
        "Edit or switch any FAQ off anytime",
      ]}
    >
      <FaqShowcase />
    </FeatureRow>

    <!-- 7 · text right, content left -->
    <FeatureRow
      tone="muted"
      reverse
      eyebrow="Human handoff"
      title="Never miss a case."
      body="When a visitor needs a person, the chat hands off to you or a teammate in real time. If no one's available, the request becomes a ticket and lands in your inbox with the full conversation- so nothing slips through."
      bullets={[
        "Live handoff from the AI to a real person",
        "Offline? The request is emailed to you",
        "Every handoff keeps the full transcript",
      ]}
    >
      <LiveSupportShowcase />
    </FeatureRow>

    <!-- 8 · text left, content right -->
    <FeatureRow
      tone="light"
      eyebrow="Widget appearance"
      title="Make the widget yours."
      body="Set the accent color, launcher icon, and position, write your own greeting, and choose whether to show branding. It matches your site without touching your code."
      bullets={[
        "Your accent color and launcher icon",
        "A custom greeting and button label",
        "Bottom-left or bottom-right",
      ]}
    >
      <WidgetCustomizeShowcase />
    </FeatureRow>

    <!-- 9 · text right, content left -->
    <FeatureRow
      tone="muted"
      reverse
      eyebrow="Callback ticket board"
      title="Turn missed handoffs into work your team can track."
      body="When no operator accepts a live request, the visitor can leave callback details and Plug & Play creates a ticket automatically. Your team can assign it, move it through three clear stages, and keep every request visible until it is resolved."
      bullets={[
        "New, In progress, and Resolved - no extra workflow to configure",
        "Drag tickets between stages or use Start, Resolve, and Reopen",
        "Assign work to the owner or an active teammate",
      ]}
    >
      <TicketsShowcase />
    </FeatureRow>

    <!-- 10 · three-column wrap-up: sites, team, tickets -->
    <section class="border-t border-slate-200 bg-slate-50">
      <div class="mx-auto max-w-6xl px-6 py-20">
        <div class="mx-auto max-w-2xl text-center">
          <p class="text-sm font-semibold uppercase tracking-widest text-sky-700">
            Built for teams
          </p>
          <h2 class="mt-4 text-3xl font-semibold tracking-tight text-slate-950 sm:text-4xl">
            Run it all from one place.
          </h2>
          <p class="mt-5 text-lg leading-8 text-slate-600">
            Every site, every teammate, every request- managed from a single login.
          </p>
        </div>

        <div class="mt-14 grid gap-6 md:grid-cols-3">
          <!-- Multiple sites -->
          <div class="flex h-full flex-col rounded-2xl border border-slate-200 bg-white p-6">
            <span
              class="flex h-11 w-11 items-center justify-center rounded-xl bg-sky-100 text-sky-700"
            >
              <svg
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="h-6 w-6"
                aria-hidden="true"
              >
                <rect x="3" y="3" width="7" height="7" rx="1.5"></rect>
                <rect x="14" y="3" width="7" height="7" rx="1.5"></rect>
                <rect x="3" y="14" width="7" height="7" rx="1.5"></rect>
                <rect x="14" y="14" width="7" height="7" rx="1.5"></rect>
              </svg>
            </span>
            <h3 class="mt-5 text-xl font-semibold text-slate-950">Run every site from one account</h3>
            <p class="mt-3 leading-7 text-slate-600">
              Each website is its own site- with separate knowledge, conversations, analytics, and
              quota. Switch between them from a single login.
            </p>
          </div>

          <!-- Team -->
          <div class="flex h-full flex-col rounded-2xl border border-slate-200 bg-white p-6">
            <span
              class="flex h-11 w-11 items-center justify-center rounded-xl bg-sky-100 text-sky-700"
            >
              <svg
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="h-6 w-6"
                aria-hidden="true"
              >
                <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path>
                <circle cx="9" cy="7" r="4"></circle>
                <path d="M22 21v-2a4 4 0 0 0-3-3.87"></path>
                <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
              </svg>
            </span>
            <h3 class="mt-5 text-xl font-semibold text-slate-950">Invite your team</h3>
            <p class="mt-3 leading-7 text-slate-600">
              Add teammates by email. They can handle live chats, answer tickets, and manage
              knowledge across all your sites- while you keep control of settings and keys.
            </p>
          </div>

          <!-- Tickets -->
          <div class="flex h-full flex-col rounded-2xl border border-slate-200 bg-white p-6">
            <span
              class="flex h-11 w-11 items-center justify-center rounded-xl bg-sky-100 text-sky-700"
            >
              <svg
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="h-6 w-6"
                aria-hidden="true"
              >
                <path d="M22 12h-6l-2 3h-4l-2-3H2"></path>
                <path
                  d="M5.45 5.11 2 12v6a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-6l-3.45-6.89A2 2 0 0 0 16.76 4H7.24a2 2 0 0 0-1.79 1.11Z"
                ></path>
              </svg>
            </span>
            <h3 class="mt-5 text-xl font-semibold text-slate-950">Keep ticket work moving</h3>
            <p class="mt-3 leading-7 text-slate-600">
              Callback requests stay visible on the three-stage board. Teammates can assign and move
              them, while the account owner can archive completed work.
            </p>
          </div>
        </div>
      </div>
    </section>
  </div>

  <!-- Closing call to action -->
  <section class="border-t border-slate-200 bg-white">
    <div class="mx-auto max-w-6xl px-6 py-20 text-center">
      <h2 class="text-3xl font-semibold tracking-tight text-slate-950 sm:text-4xl">
        Your documents already have the answers.
      </h2>
      <p class="mx-auto mt-4 max-w-2xl text-lg leading-8 text-slate-600">
        Give your customers a faster way to reach them.
      </p>
      <a
        href={NAV.register}
        class="mt-8 inline-flex rounded-lg bg-sky-600 px-6 py-3 text-sm font-medium text-white transition hover:bg-sky-700"
      >
        Go to your workspace
      </a>
    </div>
  </section>
</BaseLayout>

---
import "../styles/global.css";
import SEO from "../components/SEO.astro";
import Analytics from "../components/Analytics.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import ConsentBanner from "../components/ConsentBanner.astro";
import { SITE } from "../config";

interface Props {
  title: string;
  description?: string;
  path?: string;
  schema?: Record<string, unknown>[];
}

const { title, description, path, schema } = Astro.props;
---

<!doctype html>
<html lang={SITE.locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta name="generator" content={Astro.generator} />
    <SEO title={title} description={description} path={path} schema={schema} />
    <Analytics />
  </head>
  <body class="flex min-h-screen flex-col bg-slate-50 text-slate-900 antialiased">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
    <ConsentBanner />
  </body>
</html>

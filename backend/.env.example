# DeepSeek (OpenAI-compatible) credentials
DEEPSEEK_API_KEY=sk-your-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
# V4 thinking mode. Keep false for knowledge-base answers (faster/cheaper).
DEEPSEEK_THINKING=false

# OpenAI (speech + embeddings). Required for voice and RAG retrieval.
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_STT_MODEL=gpt-4o-mini-transcribe
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=alloy
# API-based embeddings (no local PyTorch, so the backend fits serverless/Lambda).
# Changing the model/dim requires a pgvector migration + full re-index.
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536

# Database (overridden by docker-compose for the backend service)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/support
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=support

# CORS
FRONTEND_ORIGIN=http://localhost:5173
# Comma-separated customer domains allowed to embed the widget and call the
# public chat API cross-origin. Use "*" to allow any origin (the site key still
# authorizes the tenant). Example: https://acme.com,https://shop.acme.com
WIDGET_ALLOWED_ORIGINS=

# --- Production auth (leave empty for local dev) --------------------------
# Shared secret injected by the Cloudflare Worker on every request and verified
# by the backend. Empty = check disabled. Must match the Worker's SHARED_SECRET.
EDGE_SHARED_SECRET=
# Supabase Auth: when SUPABASE_JWT_SECRET is set, admin routes (knowledge,
# settings, conversations, analytics) require a valid Supabase JWT. Empty =
# admin auth disabled (dev only).
SUPABASE_URL=
SUPABASE_JWT_SECRET=

# Voice uses a WebSocket (unsupported on AWS Lambda Function URLs). Keep true
# for local dev / container hosts; set false for the serverless deployment.
VOICE_ENABLED=true
# Force pgBouncer-safe DB settings. Auto-enabled when DATABASE_URL uses the
# Supabase :6543 transaction pooler, so normally leave this false.
DB_PGBOUNCER=false

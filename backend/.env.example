# DeepSeek (OpenAI-compatible) credentials
DEEPSEEK_API_KEY=sk-your-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
# V4 thinking mode. Keep false for knowledge-base answers (faster/cheaper).
DEEPSEEK_THINKING=false
# Optional DeepSeek-generated summaries shown above stored chat transcripts.
# Disabled by default to avoid an extra model call when opening history.
CONVERSATION_SUMMARIES_ENABLED=false

# OpenAI embeddings. Required for RAG retrieval.
OPENAI_API_KEY=sk-your-openai-key-here
# API-based embeddings (no local PyTorch, so the backend fits serverless/Lambda).
# Changing the model/dim requires a pgvector migration + full re-index.
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIM=1536

# Retrieval / chunking. Kept modest so the injected context stays small and
# time-to-first-token stays low. Chunking changes only affect newly ingested
# documents (run reingest_documents.py to re-chunk existing ones).
RAG_TOP_K=12
CHUNK_SIZE=1200
CHUNK_OVERLAP=200

# Rewrite follow-up messages into standalone retrieval queries using the most
# recent conversation turns. Failures automatically fall back to the literal query.
RAG_QUERY_CONTEXTUALIZATION=true
RAG_QUERY_CONTEXT_MESSAGES=6
RAG_QUERY_CONTEXT_CHARS=6000
RAG_QUERY_CONTEXT_TIMEOUT=6.0

# Reranking (Jina). Retrieves a wider candidate set, then a multilingual
# cross-encoder reorders it against the question and keeps the best RAG_TOP_K.
# Leave JINA_API_KEY empty to disable (retrieval falls back to cosine-score order).
RAG_RERANKER=true
JINA_API_KEY=
JINA_RERANKER_MODEL=jina-reranker-v2-base-multilingual
RAG_RERANK_CANDIDATES=24
RAG_RERANK_SNIPPET_CHARS=400
RAG_RERANK_TIMEOUT=6.0

# Jina Reader (r.jina.ai) fetches and cleans web pages for URL ingestion;
# reuses JINA_API_KEY. The timeout is generous because Reader renders JS-heavy
# pages server-side. REMOVE_SELECTOR strips site chrome before storage
# (comma-separated; empty disables). TARGET_SELECTOR restricts extraction to
# one CSS selector (site-specific; usually left empty).
JINA_READER_TIMEOUT=30.0
JINA_READER_FORMAT=text
JINA_READER_REMOVE_SELECTOR=nav,header,footer,aside,form
JINA_READER_TARGET_SELECTOR=

# Database (overridden by docker-compose for the backend service)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/support
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=support

# Asynchronous document ingestion (S3 upload + SQS-triggered ingestion Lambda).
# Both required for file/URL uploads - the upload endpoint returns 503 without
# them. FAQ entries are ingested synchronously and work with these unset.
AWS_REGION=eu-central-1
INGESTION_BUCKET=
INGESTION_QUEUE_URL=

# CORS
FRONTEND_ORIGIN=http://localhost:5173
# Admin and widget-CDN origins allowed to call the API. The customer website is
# validated per installation during the origin-bound widget bootstrap.
WIDGET_ALLOWED_ORIGINS=
WIDGET_SESSION_SECRET=replace-with-a-separate-long-random-secret
WIDGET_SESSION_TTL_SECONDS=900

# Live human escalation (visitor -> operator handoff over Cloudflare Durable
# Objects). Dark by default: this global flag must be on in BOTH the Lambda and
# the Worker, plus the per-site toggle in Settings. See
# docs/LIVE_HUMAN_ESCALATION.md for the staged rollout.
LIVE_HUMAN_ESCALATION_ENABLED=false
LIVE_CONVERSATION_TOKEN_TTL_SECONDS=14400
LIVE_SOCKET_TICKET_TTL_SECONDS=60
LIVE_ACCEPT_TIMEOUT_SECONDS=60

# Visitor abuse moderation (OpenAI Moderation API; reuses OPENAI_API_KEY, the
# endpoint is free). Widget visitors only - admin test chat is never moderated.
# Flagged messages get a canned warning instead of an answer; the strike limit
# auto-closes the conversation. Fail-open: an API error/timeout or a missing
# key never blocks a normal answer. Global kill-switch; each site also has its
# own toggle in Settings (on by default, migration 0023).
MODERATION_ENABLED=true
MODERATION_MODEL=omni-moderation-latest
MODERATION_TIMEOUT=5.0
MODERATION_STRIKE_LIMIT=3

# --- Production auth (leave empty for local dev) --------------------------
# Shared secret injected by the Cloudflare Worker on every request and verified
# by the backend. Empty = check disabled. Must match the Worker's SHARED_SECRET.
EDGE_SHARED_SECRET=
# Enable only after the Cloudflare Worker is validating Turnstile and injecting
# X-Turnstile-Verified on successful /widget/session requests.
TURNSTILE_REQUIRED=false
# Supabase Auth. Admin routes (knowledge, settings, conversations, analytics)
# require a valid Supabase JWT. The scheme is auto-selected from each token:
#   * New asymmetric signing keys (ES256/RS256) -> set SUPABASE_URL; the backend
#     verifies against {SUPABASE_URL}/auth/v1/.well-known/jwks.json. This is the
#     path for projects migrated to JWT Signing Keys (the current default).
#   * Legacy shared secret (HS256) -> set SUPABASE_JWT_SECRET (Project Settings
#     -> JWT Keys -> Legacy JWT Secret). Only works if that secret is still the
#     active signing key.
# Setting either one enables admin auth; leave both empty for dev (no login).
SUPABASE_URL=
SUPABASE_JWT_SECRET=
# Team invites, password recovery, and MFA lookups. The service-role key
# (Project Settings -> API) lets the backend create an invited member's account
# and generate password-recovery links via the Admin API (generate_link), and
# look up a user's MFA factors for aal2 enforcement; empty disables all three,
# but invites still work for existing accounts.
# APP_BASE_URL is the invite/recovery-link redirect target and must be listed
# in Supabase Auth's Redirect URLs; empty falls back to the project's Site URL.
SUPABASE_SERVICE_ROLE_KEY=
APP_BASE_URL=
# Require an aal2 (MFA-verified) token on admin routes for users who have a
# verified MFA factor (checked via the Admin API and cached). Fails OPEN when
# the key/URL is unset or the lookup errors, so an Admin API outage never locks
# the dashboard out; this flag is the operator kill-switch.
MFA_ENFORCEMENT_ENABLED=true
SUPABASE_MFA_CACHE_SECONDS=300

# --- Stripe billing (leave empty to disable billing entirely) --------------
# Secret API key and webhook signing secret from the Stripe Dashboard.
# Point the Stripe webhook endpoint at {public API}/billing/webhook (routed
# through the Cloudflare Worker, which injects the edge secret). Checkout
# success/cancel and the billing-portal return URL derive from APP_BASE_URL.
# Enable Stripe Tax for EU VAT. See docs/BILLING.md for full setup.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Price IDs (not secret). Yearly = 10x monthly (2 months free). One per
# plan/interval, plus a one-time 1,000-message top-up pack (Phase 2).
STRIPE_PRICE_STARTER_MONTH=
STRIPE_PRICE_STARTER_YEAR=
STRIPE_PRICE_PRO_MONTH=
STRIPE_PRICE_PRO_YEAR=
STRIPE_PRICE_BUSINESS_MONTH=
STRIPE_PRICE_BUSINESS_YEAR=
STRIPE_PRICE_TOPUP=

# Force pgBouncer-safe DB settings. Auto-enabled when DATABASE_URL uses the
# Supabase :6543 transaction pooler, so normally leave this false.
DB_PGBOUNCER=false

VITE_API_BASE=http://localhost:8000

# Admin auth (Supabase). Leave both empty for local dev — the app then
# renders without a login, matching the backend when SUPABASE_JWT_SECRET is unset.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# URL of the deployed widget loader (widget.js); used to build the install snippet.
VITE_WIDGET_SRC=

# Public Cloudflare Turnstile site key used by the platform-hosted widget iframe.
# Leave empty only for local development with server enforcement disabled.
VITE_TURNSTILE_SITE_KEY=